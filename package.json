{
  "name": "slidev-theme-atlas",
  "version": "0.0.1",
  "private": true,
  "description": "A starter Slidev theme named atlas.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "slidev",
    "slidev-theme",
    "theme"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@slidev/types": "^52.9.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.9.1",
    "@unocss/transformer-directives": "^66.6.7",
    "@vue/compiler-sfc": "^3.5.0",
    "prettier": "^3.3.3"
  },
  "slidev": {
    "colorSchema": "light",
    "aspectRatio": "16/9"
  }
}
