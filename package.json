{
  "name": "slidev-theme-atlas",
  "version": "0.1.0",
  "description": "A structured Slidev theme for academic and technical presentations.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "slidev",
    "slidev-theme",
    "theme",
    "atlas",
    "academic",
    "presentation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R-Sh1ki/slidev-theme-atlas.git"
  },
  "homepage": "https://github.com/R-Sh1ki/slidev-theme-atlas#readme",
  "bugs": {
    "url": "https://github.com/R-Sh1ki/slidev-theme-atlas/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "assets",
    "components",
    "docs/previews",
    "layouts",
    "styles",
    "uno.config.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.9.1",
    "@slidev/types": "^52.9.1",
    "@unocss/transformer-directives": "^66.6.7",
    "@vue/compiler-sfc": "^3.5.0",
    "playwright-chromium": "^1.60.0",
    "prettier": "^3.3.3"
  },
  "slidev": {
    "colorSchema": "light",
    "aspectRatio": "16/9"
  }
}
